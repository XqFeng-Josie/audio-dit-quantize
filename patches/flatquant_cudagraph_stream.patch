diff --git a/deploy/kernels/gemm.cu b/deploy/kernels/gemm.cu
index b8f6643..5bf32f9 100644
--- a/deploy/kernels/gemm.cu
+++ b/deploy/kernels/gemm.cu
@@ -1,5 +1,6 @@
 #include <cutlass/gemm/device/gemm.h>
 #include <gemm.h>
+#include <ATen/cuda/CUDAContext.h>  // at::cuda::getCurrentCUDAStream (CUDA-graph capture safety)
 
 
 
@@ -38,7 +39,11 @@ void matmul_host(
             {1,                                0}
     };
 
-    auto status = gemmOp(arguments);
+    // Launch on the CURRENT PyTorch stream (not the legacy default stream): CUTLASS's
+    // operator() defaults stream=nullptr -> default stream, which is NOT captured by
+    // CUDA-graph (PyTorch captures the current stream) -> the GEMM is silently dropped
+    // on replay and the output stays zero. Passing the current stream makes it capturable.
+    auto status = gemmOp(arguments, nullptr, at::cuda::getCurrentCUDAStream());
 
     ensure(status == cutlass::Status::kSuccess,
            cutlassGetStatusString(status));
